# Blink credentials — used only by setup_auth.py for the one-time 2FA flow
BLINK_USERNAME=your@email.com
BLINK_PASSWORD=yourpassword

# Webhook secret — any random string; must match the header Tasker sends
# Generate one: python -c "import secrets; print(secrets.token_hex(24))"
WEBHOOK_SECRET=change_me_to_a_random_string

# Telegram Bot — get these in 2 minutes by messaging @BotFather on Telegram
#
# Setup:
# 1. Open Telegram → Search for @BotFather
# 2. Send /newbot → give it a name (e.g., "BlinkBot") and username (must be unique)
# 3. BotFather replies with your BOT TOKEN (e.g., 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)
# 4. Message your new bot once, then run:
#    curl "https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates"
# 5. In the JSON response, find "chat": {"id": 123456789} — that's your CHAT_ID
# 6. Paste both values below
#
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
